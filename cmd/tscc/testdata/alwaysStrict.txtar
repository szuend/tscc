# Strict mode makes `var arguments = []` a compile error, but tsc still emits
# the JS (matching upstream baseline alwaysStrict.errors.txt / alwaysStrict.js).
! exec tscc --target es2015 --out-js a.js a.ts
stderr 'TS1100'
cmp a.js a.js.golden

-- a.ts --
function f() {
    var arguments = [];
}
-- a.js.golden --
"use strict";
function f() {
    var arguments = [];
}
