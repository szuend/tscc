# --out-deps on its own is the "tell me the input set for foo.ts" use case.
# No --out-js means no JavaScript is written — explicit outputs only. The
# depsfile is the sole artifact, so it's also the Make target.
exec tscc --target es2022 --out-deps a.d a.ts
! stderr .
exists a.d
! exists a.js
! exists b.js
grep 'a\.d: ' a.d
grep 'a\.ts' a.d
grep 'b\.ts' a.d
! grep 'bundled:///' a.d
! grep 'lib\.[a-z0-9.]+\.d\.ts' a.d

# --out-map without --out-js or --out-dts uses the map as the deps target.
exec tscc --out-map m.js.map --out-deps m.d a.ts
grep 'm\.js\.map: ' m.d
grep 'a\.ts' m.d

-- a.ts --
import { x } from "./b.js";
export const y: number = x + 1;
-- b.ts --
export const x: number = 41;
