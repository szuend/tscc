// https://github.com/microsoft/TypeScript/issues/58150

function doSthWithParams(params: unknown) {
  if (typeof params !== "object") {
    return {};
  }

  return {
    c: "foo",
    p: "bar",
    s: "baz",
  };
}

const bar = {
  p: null,
  s: null,
  ...doSthWithParams({
    p: "hello",
    s: "world",
  }),
};
