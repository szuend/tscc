-- unaryPlus.ts --
// allowed per spec
var a = +1;
var b = +(<any>"");
enum E { some, thing };
var c = +E.some;

// also allowed, used to be errors
var x = +"3"; //should be valid
var y = -"3"; // should be valid
var z = ~"3"; // should be valid
-- unaryPlus.js.golden --
"use strict";
// allowed per spec
var a = +1;
var b = +"";
var E;
(function (E) {
    E[E["some"] = 0] = "some";
    E[E["thing"] = 1] = "thing";
})(E || (E = {}));
;
var c = +E.some;
// also allowed, used to be errors
var x = +"3"; //should be valid
var y = -"3"; // should be valid
var z = ~"3"; // should be valid
