"use strict";
function clonePet(pet, fullCopy) {
    return Object.assign({ name: pet.name, kind: pet.kind }, (fullCopy && pet));
}
function billOwner(pet) {
    return Object.assign(Object.assign({}, (pet.owner && pet)), { paid: false });
}
