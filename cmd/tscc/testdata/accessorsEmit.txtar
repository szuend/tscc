# Class getter/setter accessors are emitted correctly at es2015 target.
exec tscc --target es2015 a.ts
! stderr .
cmp a.js a.js.golden

-- a.ts --
class Result { }

class Test {
    get Property(): Result {
        var x = 1;
        return null;
    }
}

class Test2 {
    get Property() {
        var x = 1;
        return null;
    }
}
-- a.js.golden --
"use strict";
class Result {
}
class Test {
    get Property() {
        var x = 1;
        return null;
    }
}
class Test2 {
    get Property() {
        var x = 1;
        return null;
    }
}
