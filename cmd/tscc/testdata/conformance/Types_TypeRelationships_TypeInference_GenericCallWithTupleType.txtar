interface I<T, U> {
    tuple1: [T, U];
} 

var i1: I<string, number>;
declare var i1: I<string, number>;
declare var i2: I<{}, {}>;

// no error
i1.tuple1 = ["foo", 5];
var e1 = i1.tuple1[0];  // string
var e2 = i1.tuple1[1];  // number
