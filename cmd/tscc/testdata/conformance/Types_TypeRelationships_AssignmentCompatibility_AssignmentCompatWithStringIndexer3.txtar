interface Base { foo: string; }
interface Derived extends Base { bar: string; }
interface Derived2 extends Derived { baz: string; }

declare var a: A;
declare var b1: { [x: string]: string; };
a = b1; // error
b1 = a; // error

namespace Generics {
    class A<T extends Derived> {
        [x: string]: T;
    }
   
