/**
 * Syntax constructions of switch statement
 *
 * @path ch12/12.11/S12.11_A3_T4.js
 * @description Using "case" that has no Expresson after it. "CaseClause: case Expression : [StatementList]"
 * @negative
 */

function SwitchTest(value){
  var result = 0;
  
  switch(value) {
    case:
      result += 2;
    default:
      result += 32;
      break;
  }
  
  return result;
}

var x = SwitchTest(0);

